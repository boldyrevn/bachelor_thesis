{
  "mcp": {
    "allowed": [
      "chrome-devtools"
    ]
  },
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "--isolated",
        "chrome-devtools-mcp@latest"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(ruff *)",
      "Bash(source *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(docker run *)",
      "Bash(docker build *)",
      "Bash(git reset *)",
      "Bash(.venv/bin/pytest *)",
      "Bash(.venv/bin/pip *)",
      "Bash(docker ps)",
      "Bash(.venv/bin/ruff *)",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__press_key",
      "Bash(.venv/bin/python *)",
      "Bash(true)",
      "Bash(docker logs *)",
      "Bash(docker exec *)",
      "Bash(/users/nikita.boldyrev/code/bachelor_thesis/.venv/bin/python3 *)",
      "Bash(npx *)",
      "mcp__chrome-devtools__fill",
      "mcp__chrome-devtools__get_network_request",
      "Bash(sleep *)",
      "Bash(curl *)",
      "Bash(python3 *)",
      "Bash(docker compose up *)",
      "Bash(docker compose restart *)",
      "Bash(../.venv/bin/python *)"
    ]
  },
  "$version": 3
}