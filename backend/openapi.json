  "components": {
    "schemas": {
      "ConnectionCreateRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "connection_type": {
            "$ref": "#/components/schemas/ConnectionType"
          },
          "config": {
            "type": "object",
            "title": "Config"
          },
          "secrets": {
            "type": "object",
            "title": "Secrets"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          }
        },
        "type": "object",
        "required": [
          "name",
          "connection_type",
          "config",
          "secrets"
        ],
        "title": "ConnectionCreateRequest",
        "description": "Request model for creating a connection."
      },
      "ConnectionType": {
        "type": "string",
        "enum": [
          "postgres",
          "clickhouse",
          "s3",
          "spark"
        ],
        "title": "ConnectionType",
        "description": "Supported connection types."
      },
      "ConnectionUpdateRequest": {
        "properties": {
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          },
          "config": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Config"
          },
          "secrets": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Secrets"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          }
        },
        "type": "object",
        "title": "ConnectionUpdateRequest",
        "description": "Request model for updating a connection."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
