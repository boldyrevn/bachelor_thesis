        "tags": [
          "connections"
        ],
        "summary": "Update connection",
        "description": "Update an existing connection.\n\nOnly provided fields will be updated.",
        "operationId": "update_connection_api_v1_connections__connection_id__put",
        "parameters": [
          {
            "name": "connection_id",
            "in": "path",
            "required": true,
