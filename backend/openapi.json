        ],
        "summary": "Hello Endpoint",
        "description": "Simple hello endpoint for testing.",
        "operationId": "hello_endpoint_api_v1_hello_get",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "World",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "Response Hello Endpoint Api V1 Hello Get"
                }
              }
